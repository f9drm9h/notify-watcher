        "will direct", "new director"] },
      "official_signals": { "weight": 4, "terms": ["confirm", "announce",
        "official", "greenlit", "greenlight"] },
      "moderate_signals": { "weight": 3, "terms": ["review", "interview",
        "set photo", "behind the scenes", "box office", "rumor", "rumour",
        "report", "leak", "preview", "first reactions", "early reactions"] }
    },
    "noise_penalties": {
      "listicle": { "weight": -6, "terms": ["best movies", "worst movies",
        "ranked", "ranking", "tier list", "movies like", "most anticipated",
        "top 10", "top 20", "top 25"] },
      "opinion": { "weight": -6, "terms": ["opinion", "editorial", "hot take",
        "i watched", "why i "] },
      "speculation": { "weight": -5, "terms": ["could", "might", "maybe",
        "what if", "here's why", "reasons why", "fan theory", "fans want",
        "we want", "predict", "speculation", "rumored to"] },
      "clickbait": { "weight": -5, "terms": ["you won't believe", "shocking",
        "this is why", "needs to", "deserves"] }
    },
    "thresholds": { "high": 7, "moderate": 4 }
  }
}
