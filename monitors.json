{
  "_location_comment": "Home location, shared by the geo-aware monitors (quakes, weather). Update these to move every location-based alert at once.",
  "location": {
    "name": "Santo Domingo Este",
    "latitude": 18.521661,
    "longitude": -69.8224191,
    "timezone": "America/Santo_Domingo"
  },

  "quakes": {
    "_comment": "Nearby earthquakes (USGS). Routed by magnitude AND great-circle distance from location: live push within live_radius_km at >= live_min_mag, daily digest within digest_radius_km at >= digest_min_mag, else dropped.",
    "url": "https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/2.5_day.geojson",
    "live_radius_km": 600,
    "live_min_mag": 4.5,
    "digest_radius_km": 300,
    "digest_min_mag": 3.0
  },

  "weather": {
    "_comment": "Tropical storm / hurricane alerts (US National Hurricane Center Atlantic ATOM feed). An entry naming a region_term goes live if it also carries a live_term (watch/warning), else to the daily digest. Off-region Atlantic activity is ignored, so it stays quiet outside threats to our area.",
    "url": "https://www.nhc.noaa.gov/index-at.xml",
    "region_terms": ["dominican", "hispaniola", "haiti", "caribbean", "puerto rico",
                     "mona passage", "leeward", "windward", "antilles", "turks and caicos"],
    "live_terms": ["warning", "watch"]
  },

  "air_quality": {
    "_comment": "Local air quality (Open-Meteo, US AQI). Alerts when AQI enters a band at or above alert_band_index (0=Good,1=Moderate,2=Unhealthy for sensitive,3=Unhealthy,4=Very unhealthy,5=Hazardous), at most once per worsening band per day.",
    "alert_band_index": 2
  },

  "fx": {
    "_comment": "USD -> DOP exchange rate (open.er-api, free). Pushes when the rate crosses out of the [low, high] band (low/high or back inside). Tune low/high to the range you care about.",
    "base": "USD",
    "quote": "DOP",
    "low": 57.0,
    "high": 61.0
  },

  "scoring": {
    "source_weights": {
      "regulatory": 5,
      "agency": 4,
      "gov_data": 3,
      "trade": 1
    },
    "signal_bonuses": {
      "action_terms": {
        "weight": 2,
        "terms": ["approves", "approved", "authorizes", "authorized", "recalls",
                  "recall", "halts", "first", "phase 3", "phase iii",
                  "breakthrough", "greenlights", "clearance", "cleared",
                  "milestone", "ignition", "record"]
      },
      "watch_match": {
        "weight": 2
      },
      "safety_terms": {
        "weight": 2,
        "terms": ["safety alert", "outbreak", "contraindication", "shortage",
                  "warning", "blackout"]
      }
    },
    "noise_penalties": {
      "hype_terms": {
        "weight": -2,
        "terms": ["promising", "could", "may ", "might", "in mice",
                  "study suggests", "potential", "aims to", "hopes to",
                  "expected to", "reportedly"]
      }
    },
    "thresholds": {
      "breakthrough": 8,
      "high": 6,
      "moderate": 4
    }
  },

  "fda": {
    "source_weight": "regulatory",
    "application_types": ["NDA", "BLA"],
    "url": "https://api.fda.gov/drug/drugsfda.json?search=submissions.submission_status:AP&sort=submissions.submission_status_date:desc&limit=25",
    "keywords": ["cancer", "oncology", "hiv", "alzheimer", "parkinson",
                 "diabetes", "vaccine", "gene therapy", "influenza", "flu",
                 "dengue", "obesity", "hepatitis", "tuberculosis"]
  },

  "energy": {
    "keywords": ["fusion", "grid", "battery", "storage", "nuclear", "solar",
                 "reactor", "blackout", "transmission", "smr", "renewable",
                 "hydrogen", "wind"],
    "sources": [
      {"name": "EIA Today in Energy", "url": "https://www.eia.gov/rss/todayinenergy.xml", "weight": "gov_data"},
      {"name": "World Nuclear News", "url": "https://world-nuclear-news.org/rss", "weight": "trade"}
    ]
  },

  "_digest_comment": "max_per_source caps how many items any one source (a film, game, or feed) may hold in the shared buffer, so a high-volume source can't evict the low-volume domain monitors before the daily flush. Evictions and the flush both rank by score, so the most important pending items survive and surface first.",
  "digest": {
    "max_buffer": 120,
    "max_per_source": 8,
    "max_items_in_message": 30
  },

  "games_scoring": {
    "_comment": "Importance scorer for game news headlines. score = source_weight + one-shot signal bonuses - one-shot noise penalties; tier = highest threshold met. Matching is case-insensitive SUBSTRING, so terms must not be substrings of innocent words (e.g. 'review' would match 'preview'). high -> live push, moderate -> daily digest, below moderate -> dropped.",
    "source_weights": { "official": 4, "tier1": 1, "unknown": 0 },
    "source_tiers": {
      "official": ["playstation", "xbox wire", "xbox.com", "nintendo", "steam",
                   "rockstar", "bethesda", "ubisoft", "ea.com", "sony interactive"],
      "tier1": ["ign", "gamespot", "eurogamer", "polygon", "vgc",
                "video games chronicle", "pc gamer", "game informer", "bloomberg",
                "kotaku", "the verge", "gamesradar", "gamesindustry"]
    },
    "signal_bonuses": {
      "launch_signals": { "weight": 5, "terms": ["release date", "launch date",
        "release window", "release timing", "delayed", "delay", "pushed back",
        "postponed", "out now", "launches"] },
      "reveal_signals": { "weight": 5, "terms": ["trailer", "gameplay", "reveal",
        "first look", "showcase", "world premiere", "screenshot"] },
      "content_signals": { "weight": 4, "terms": ["beta", "playtest", "dlc",
        "expansion", "season pass", "sequel", "major update", "content update",
        "roadmap", "remake", "remaster"] },
      "official_signals": { "weight": 4, "terms": ["confirm", "announce",
        "official", "statement", "dev diary", "developer update"] },
      "moderate_signals": { "weight": 3, "terms": ["leak", "rumor", "rumour",
        "interview", "preview", "hands-on", "impressions", "steam page",
        "store page", "wishlist", "esrb", "pegi", "listing", "report"] }
    },
    "noise_penalties": {
      "listicle": { "weight": -6, "terms": ["top 10", "top 20", "top 25",
        "ranked", "ranking", "tier list", "games like", "most anticipated",
        "best games", "worst games"] },
      "opinion": { "weight": -6, "terms": ["opinion", "editorial", "hot take",
        "i played", "why i "] },
      "speculation": { "weight": -5, "terms": ["could", "might", "maybe",
        "what if", "here's why", "reasons why", "fan theory", "fans want",
        "we want", "predict", "speculation", "rumored to"] },
      "clickbait": { "weight": -5, "terms": ["you won't believe", "shocking",
        "this is why", "needs to", "deserves"] }
    },
    "thresholds": { "high": 7, "moderate": 4 }
  },

