{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "reminders.json",
  "description": "Expiry/deadline reminders and monthly bills (see notify_watcher/topics/reminders.py and bills.py). Required fields mirror what the topics need to act on an entry: a reminder without name+date or a bill without name+due_day is silently skipped at runtime, which is exactly what CI should catch.",
  "type": "object",
  "properties": {
    "reminders": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "date"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "name": { "type": "string", "minLength": 1 },
          "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
          "lead_days": {
            "type": "array",
            "items": { "type": "integer", "minimum": 0 }
          },
          "recurring": { "const": "yearly" },
          "note": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "bills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "due_day"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "name": { "type": "string", "minLength": 1 },
          "due_day": { "type": "integer", "minimum": 1, "maximum": 31 },
          "lead_days": {
            "type": "array",
            "items": { "type": "integer", "minimum": 0 }
          },
          "note": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "patternProperties": { "^_": {} },
  "additionalProperties": false
}
