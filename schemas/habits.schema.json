{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "habits.json",
  "description": "Recurring daytime habit nudges (see notify_watcher/topics/habits.py). A habit without name, hours, or messages is silently skipped at runtime; title and tag have code fallbacks but title is required here because a push without one is never intended.",
  "type": "object",
  "properties": {
    "habits": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "title", "hours", "messages"],
        "properties": {
          "name": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$" },
          "title": { "type": "string", "minLength": 1 },
          "tag": { "type": "string", "minLength": 1 },
          "enabled": { "type": "boolean" },
          "hours": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "integer", "minimum": 0, "maximum": 23 }
          },
          "messages": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "patternProperties": { "^_": {} },
  "additionalProperties": false
}
