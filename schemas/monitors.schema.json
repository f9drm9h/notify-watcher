{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "monitors.json",
  "description": "Domain-monitoring policy (see notify_watcher/config.py). Strategy (docs/design/04): the high-blast-radius sections that shape EVERY push (location, quiet_hours, priority, watchdog, scoring) are validated strictly; unknown top-level sections are allowed so adding a topic never requires a schema edit. Per-topic sections can be tightened here incrementally. Keys starting with _ are comments and allowed everywhere.",
  "type": "object",
  "properties": {
    "location": {
      "type": "object",
      "required": ["name", "latitude", "longitude", "timezone"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
        "longitude": { "type": "number", "minimum": -180, "maximum": 180 },
        "timezone": { "type": "string", "minLength": 1 }
      },
      "patternProperties": { "^_": {} },
      "additionalProperties": false
    },
    "quiet_hours": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "defer_to_digest": { "type": "boolean" },
        "start": { "type": "string", "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$" },
        "end": { "type": "string", "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$" },
        "utc_offset_hours": { "type": "number", "minimum": -12, "maximum": 14 }
      },
      "patternProperties": { "^_": {} },
      "additionalProperties": false
    },
    "watchdog": {
      "type": "object",
      "properties": {
        "stale_hours": { "type": "number", "exclusiveMinimum": 0 },
        "data_stale_days": {
          "type": "object",
          "additionalProperties": { "type": "number", "exclusiveMinimum": 0 }
        }
      },
      "patternProperties": { "^_": {} },
      "additionalProperties": false
    },
    "control": {
      "type": "object",
      "properties": {
        "default_buttons": {
          "type": "object",
          "description": "topic -> button specs attached to that topic's live pushes, rendered as native Discord components. Item-level: 'read', 'more', 'later:<minutes>'. Topic-level: 'mute:<hours>', 'snooze:<hours>', 'follow:<hours>', 'unmute', 'unfollow'.",
          "patternProperties": {
            "^_": {},
            "^[A-Za-z0-9][A-Za-z0-9_-]*$": {
              "type": "array",
              "maxItems": 5,
              "items": { "type": "string", "pattern": "^(read|more|later:[0-9]{1,6}|mute:[0-9]{1,4}|snooze:[0-9]{1,4}|follow:[0-9]{1,4}|unmute|unfollow)$" }
            }
          },
          "additionalProperties": false
        }
      },
      "patternProperties": { "^_": {} },
      "additionalProperties": false
    },
    "priority": {
      "type": "object",
      "properties": {
        "threshold": { "type": "integer" },
        "digest_floor": { "type": "integer" },
        "default": { "type": "integer" },
        "ntfy_bands": {
          "type": "object",
          "patternProperties": {
            "^[0-9]+$": { "enum": ["min", "low", "default", "high", "urgent"] },
            "^_": {}
          },
          "additionalProperties": false
        },
        "rules": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["score"],
            "properties": {
              "topic": { "type": "string", "minLength": 1 },
              "severity": { "enum": ["info", "low", "moderate", "high", "critical"] },
              "source": { "type": "string", "minLength": 1 },
              "score": { "type": "integer" }
            },
            "additionalProperties": false
          }
        },
        "keyword_boosts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["terms", "add"],
            "properties": {
              "terms": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              },
              "add": { "type": "integer" }
            },
            "additionalProperties": false
          }
        },
        "source_boosts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["source", "add"],
            "properties": {
              "source": { "type": "string", "minLength": 1 },
              "add": { "type": "integer" }
            },
            "additionalProperties": false
          }
        },
        "severity_boosts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["severity", "add"],
            "properties": {
              "severity": { "enum": ["info", "low", "moderate", "high", "critical"] },
              "add": { "type": "integer" }
            },
            "additionalProperties": false
          }
        },
        "overrides": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["set"],
            "properties": {
              "topic": { "type": "string", "minLength": 1 },
              "severity": { "enum": ["info", "low", "moderate", "high", "critical"] },
              "source": { "type": "string", "minLength": 1 },
              "set": { "type": "integer" }
            },
            "additionalProperties": false
          }
        }
      },
      "patternProperties": { "^_": {} },
      "additionalProperties": false
    },
    "scoring": { "$ref": "#/$defs/scoring_config" }
  },
  "patternProperties": {
    "^_": {},
    "_scoring$": { "$ref": "#/$defs/scoring_config" }
  },
  "additionalProperties": true,
  "$defs": {
    "scoring_config": {
      "type": "object",
      "description": "Shared shape for the collector scoring engine (scoring.py): the base `scoring` section and the per-domain `*_scoring` sections (golden_sun_scoring, games_scoring, movies_scoring, ...).",
      "properties": {
        "source_weights": {
          "type": "object",
          "patternProperties": { "^_": {} },
          "additionalProperties": { "type": "number" }
        },
        "source_tiers": {
          "type": "object",
          "description": "{weight_key: [source-name fragment, ...]} — maps article sources to a source_weights key by substring match (news.py _source_weight_key).",
          "patternProperties": { "^_": {} },
          "additionalProperties": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "signal_bonuses": { "$ref": "#/$defs/term_groups" },
        "noise_penalties": { "$ref": "#/$defs/term_groups" },
        "thresholds": {
          "type": "object",
          "properties": {
            "breakthrough": { "type": "number" },
            "high": { "type": "number" },
            "moderate": { "type": "number" }
          },
          "patternProperties": { "^_": {} },
          "additionalProperties": false
        }
      },
      "patternProperties": { "^_": {} },
      "additionalProperties": false
    },
    "term_groups": {
      "type": "object",
      "patternProperties": { "^_": {} },
      "additionalProperties": {
        "type": "object",
        "required": ["weight"],
        "properties": {
          "weight": { "type": "number" },
          "terms": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": false
      }
    }
  }
}
